{
  "expo": {
    "name": "Shift Tracker",
    "slug": "shift-tracker-native",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "shifttracker",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brendenwarn.shifttracker",
      "buildNumber": "22",
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.game-center": true,
        "com.apple.developer.associated-domains": ["applinks:shifttracker.app"]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Shift Tracker uses your camera to capture receipts and expense photos.",
        "NSPhotoLibraryUsageDescription": "Shift Tracker accesses your photo library to attach receipt images to expenses.",
        "NSUserNotificationUsageDescription": "Shift Tracker sends reminders about upcoming quarterly tax payment due dates.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.shifttracker.app",
      "versionCode": 27,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shifttracker.app",
              "pathPrefix": "/auth"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#65a30d",
          "androidMode": "default",
          "androidCollapsedTitle": "Shift Tracker"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Shift Tracker to access your photos for receipts.",
          "cameraPermission": "Allow Shift Tracker to use the camera to capture receipts."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Shift Tracker to use the camera."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "5c024701-d1c9-4b3f-b439-ce9d23785856"
      }
    },
    "owner": "cyclistbw",
    "updates": {
      "url": "https://u.expo.dev/5c024701-d1c9-4b3f-b439-ce9d23785856"
    }
  }
}
